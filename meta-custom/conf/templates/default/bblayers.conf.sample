# POKY_BBLAYERS_CONF_VERSION is increased each time build/conf/bblayers.conf
# changes incompatibly
POKY_BBLAYERS_CONF_VERSION = "2"

BBPATH = "${TOPDIR}"
BBFILES ?= ""

BBLAYERS ?= " \
  /home/yassine/pi-yocto/poky/meta \
  /home/yassine/pi-yocto/poky/meta-poky \
  /home/yassine/pi-yocto/poky/meta-yocto-bsp \
  /home/yassine/pi-yocto/meta-raspberrypi \
  /home/yassine/pi-yocto/build/workspace \
  /home/yassine/pi-yocto/meta-custom \
  "
